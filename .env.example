# 管理员配置
ADMIN_USERNAME=admin
# ⚠️ 必须修改！默认密码 admin123 在生产环境会被拒绝
ADMIN_PASSWORD=your-secure-password-here

# 服务器配置
# 主监听端口
SERVER_PORT=16823
# 可选：某些托管平台会注入 PORT，优先级高于 SERVER_PORT
# PORT=16823

# 数据库配置
# 支持 sqlite 和 postgres 两种后端
DB_TYPE=sqlite
# SQLite 模式下生效
SQLITE_PATH=./data/data.db
# PostgreSQL 模式下生效，例如:
# postgres://postgres:mysecretpassword@localhost:5432/ampmanager?sslmode=disable
DATABASE_URL=
# PostgreSQL 建议示例（取消注释后替换实际值）
# DB_TYPE=postgres
# DATABASE_URL=postgres://postgres:mysecretpassword@postgres:5432/ampmanager?sslmode=disable

# JWT 配置
# ⚠️ 必须修改！至少 32 个字符，使用随机字符串
# 生成命令: openssl rand -base64 32
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_ISSUER=ampmanager
JWT_AUDIENCE=ampmanager-users

# 数据加密密钥 (用于加密存储敏感数据如上游 API Key)
# ⚠️ 强烈建议设置！必须正好 32 个字符 (AES-256)
# 生成命令: openssl rand -base64 24 | head -c 32
# 如果不设置，上游 API Key 将以明文存储
DATA_ENCRYPTION_KEY=

# 开发环境可设置此项跳过安全检查（生产环境禁止使用）
# ALLOW_INSECURE_DEFAULTS=true

# 开发环境数据库记忆功能
# 仅 dev.ps1 / dev.sh 开发脚本会使用，生产环境不要开启
# AMP_DEV_RUNTIME_DB_CONFIG=true

# 调试内部接口
# 仅调试排障时使用，生产环境不要开启
# AMP_DEBUG_INTERNAL_API=true

# CORS 配置
# 逗号分隔的允许来源列表，* 表示允许所有（仅开发环境使用）
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# 速率限制配置
# 认证端点每秒请求数（登录/注册）
RATE_LIMIT_AUTH_RPS=5
# 代理端点每秒请求数
RATE_LIMIT_PROXY_RPS=100

# 本地 PostgreSQL 容器辅助变量（应用本身不直接读取，供 docker compose 参考）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ampmanager
